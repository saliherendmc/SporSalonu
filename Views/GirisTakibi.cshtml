@model List<SporSalonu.Models.GirisKayitlari>

<div class="container py-4">
    <div class="row">
        <!-- Sol Taraf: Giriş Yapma Formu -->
        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4 rounded-4 mb-4">
                <h4 class="fw-bold mb-3"><i class="fas fa-door-open text-success me-2"></i>Üye Girişi</h4>
                <p class="text-muted small">Üye ID'si girin veya listeden seçin.</p>

                <form asp-action="TurnikeGecisi" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Üye Seçin</label>
                        <select name="id" class="form-select form-select-lg shadow-none" id="uyeSelect">
                            <option value="">--- Üye Seçiniz ---</option>
                            @foreach (var uye in ViewBag.UyeListesi)
                            {
                                <option value="@uye.Id">@uye.Ad @uye.Soyad (ID: @uye.Id)</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow-sm">
                        <i class="fas fa-check-circle me-2"></i>Girişi Onayla
                    </button>
                </form>

                @if (TempData["Mesaj"] != null)
                {
                    <div class="alert alert-success mt-4 animate__animated animate__fadeIn">
                        <i class="fas fa-info-circle me-2"></i>@TempData["Mesaj"]
                    </div>
                }
                @if (TempData["Hata"] != null)
                {
                    <div class="alert alert-danger mt-4">
                        @TempData["Hata"]
                    </div>
                }
            </div>
        </div>

        <!-- Sağ Taraf: Son Giriş Yapanlar -->
        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="bg-dark text-white p-3">
                    <h5 class="mb-0"><i class="fas fa-history me-2 text-warning"></i>Son Giriş Yapanlar</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="table-light">
                                <th>Üye</th>
                                <th>Giriş Saati</th>
                                <th>Tarih</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var giris in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-3 bg-light rounded-circle text-center" style="width: 35px; height: 35px; line-height: 35px;">
                                                <i class="fas fa-user text-muted"></i>
                                            </div>
                                            <span class="fw-bold">@giris.Uye?.Ad @giris.Uye?.Soyad</span>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-soft-primary text-primary">@giris.GirisZamani.ToString("HH:mm:ss")</span></td>
                                    <td class="text-muted small">@giris.GirisZamani.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>