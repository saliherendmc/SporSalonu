@model IEnumerable<SporSalonu.Models.UyelikPaketleri>

@{
    ViewData["Title"] = "Üyelik Paketleri";
}

<h1>Üyelik Paketleri</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Yeni Paket Ekle</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Paket Adı</th>
            <th>Süre (Ay)</th>
            <th>Ücret</th>
            <th>İşlemler</th> @* Yeni başlık *@
        </tr>
    </thead>
    <>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.PaketAdi</td>
                <td>@item.KacAylikPaket</td>
                <td>@item.Ucret TL</td>
                <td>
                    @* Silme Butonu *@
                    <a asp-action="Delete" asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Bu paketi silmek istediğinize emin misiniz?')">
                        Sil
                    </a>
                </td>
            </tr>
        }
    
    </tbody>
</table>