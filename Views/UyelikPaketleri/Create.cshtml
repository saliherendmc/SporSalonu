@model SporSalonu.Models.UyelikPaketleri

@{
    ViewData["Title"] = "Yeni Paket Ekle";
}

<h1>Yeni Paket Oluştur</h1>
<div asp-validation-summary="All" class="text-danger"></div>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div class="form-group">
                <label class="control-label">Paket Adı</label>
                <input asp-for="PaketAdi" class="form-control" />
            </div>
            <div class="form-group">
                <label class="control-label">Kaç Aylık?</label>
                <input asp-for="KacAylikPaket" class="form-control" type="number" />
            </div>
            <div class="form-group">
                <label class="control-label">Ücret (TL)</label>
                <input asp-for="Ucret" class="form-control" type="text" />
            </div>
            <div class="form-group">
                <label class="control-label">Açıklama</label>
                <textarea asp-for="Aciklama" class="form-control"></textarea>
            </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Kaydet" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
            </div>
        </form>
    </div>
</div>