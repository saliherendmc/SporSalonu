@model SporSalonu.Models.Uyeler

<h1>Yeni Üye Kaydı</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div class="form-group">
                <label>Ad</label>
                <input asp-for="Ad" class="form-control" />
            </div>
            <div class="form-group">
                <label>Soyad</label>
                <input asp-for="Soyad" class="form-control" />
            </div>
            <div class="form-group">
                <label>Telefon</label>
                <input asp-for="Telefon" class="form-control" />
            </div>
            <div class="form-group">
                <label>Üyelik Paketi Seçin</label>
                <select asp-for="UyelikPaketiId" class="form-control" asp-items="ViewBag.Paketler"></select>
            </div>
            <br />
            <input type="submit" value="Üyeyi Kaydet" class="btn btn-success" />
        </form>
    </div>
</div>