@model SporSalonu.Models.Olcumler
@{
    Layout = "_Layout";
    ViewData["Title"] = "Yeni Ölçüm Ekle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <!-- Geri Dön Butonu -->
            <a asp-action="Profilim" class="text-decoration-none text-secondary small fw-bold mb-3 d-inline-block">
                <i class="fas fa-arrow-left me-1"></i> Profile Dön
            </a>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <!-- Kart Başlığı -->
                <div class="card-header bg-primary py-4 text-center border-0">
                    <div class="bg-white bg-opacity-20 rounded-circle p-3 d-inline-block mb-3">
                        <i class="fas fa-weight-hanging fa-2x text-white"></i>
                    </div>
                    <h3 class="text-white fw-bold mb-0">Yeni Ölçüm</h3>
                    <p class="text-white text-opacity-75 small mb-0">İlerlemeni kaydet ve hedefine bir adım daha yaklaş!</p>
                </div>

                <!-- Form Alanı -->
                <div class="card-body p-4 p-md-5">
                    <form asp-action="OlcumEkle" method="post" class="needs-validation">

                        <!-- Kilo Input -->
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark small">KİLO (kg)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3">
                                    <i class="fas fa-weight text-muted"></i>
                                </span>
                                <input type="number" step="0.1" name="Kilo" class="form-control bg-light border-start-0 rounded-end-3 py-2" placeholder="Örn: 75.5" required>
                            </div>
                        </div>

                        <!-- Boy Input -->
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark small">BOY (cm)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3">
                                    <i class="fas fa-ruler-vertical text-muted"></i>
                                </span>
                                <input type="number" name="Boy" class="form-control bg-light border-start-0 rounded-end-3 py-2" placeholder="Örn: 180" required>
                            </div>
                        </div>

                        <!-- Yağ Oranı Input -->
                        <div class="mb-5">
                            <label class="form-label fw-bold text-dark small">YAĞ ORANI (%)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3">
                                    <i class="fas fa-percent text-muted"></i>
                                </span>
                                <input type="number" step="0.1" name="YagOrani" class="form-control bg-light border-start-0 rounded-end-3 py-2" placeholder="Örn: 15.2" required>
                            </div>
                        </div>

                        <!-- Kaydet Butonu -->
                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm py-3 transition-all">
                            Ölçümü Kaydet <i class="fas fa-save ms-2"></i>
                        </button>
                    </form>
                </div>
            </div>

            <!-- Bilgi Notu -->
            <div class="text-center mt-4">
                <p class="text-muted small">
                    <i class="fas fa-info-circle me-1"></i> Ölçümlerini her hafta aynı gün ve saatte yapman daha tutarlı sonuçlar verir.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Özel CSS Güzelleştirmeleri */
    body {
        background-color: #f8f9fa;
    }

    .card {
        transition: transform 0.3s ease;
    }

    .input-group-text {
        border-color: #e9ecef;
    }

    .form-control {
        border-color: #e9ecef;
    }

        .form-control:focus {
            background-color: #fff !important;
            border-color: #4e73df;
            box-shadow: 0 0 0 0.25rem rgba(78, 115, 223, 0.1);
        }

    .btn-primary {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
        border: none;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(78, 115, 223, 0.4) !important;
        }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>