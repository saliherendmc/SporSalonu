@model List<SporSalonu.Models.GirisKayitlari>
@{
    ViewData["Title"] = "Giris Takibi";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-4 bg-primary text-white">
                <h4 class="fw-bold mb-3"><i class="fas fa-barcode me-2"></i>Barkod Girişi</h4>
                <form asp-action="TurnikeGecisi" method="post">
                    <input type="number" name="id" class="form-control form-control-lg mb-3 text-center"
                           placeholder="Üye ID Okutun" autofocus required>
                    <button type="submit" class="btn btn-light w-100 fw-bold">Onayla</button>
                </form>
                @if (TempData["Mesaj"] != null)
                {
                    <div class="alert alert-light mt-3 small text-success">@TempData["Mesaj"]</div>
                }
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Üye Adı Soyadı</th>
                            <th>Giriş Saati</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Uye?.Ad @item.Uye?.Soyad</td>
                                <td>@item.GirisZamani.ToString("HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>