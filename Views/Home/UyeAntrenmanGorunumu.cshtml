@model List<SporSalonu.Models.AntrenmanProgramlari>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Antrenman Programım";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold">💪 Haftalık Antrenman Planın</h2>
        <p class="text-muted">Hedeflerine ulaşmak için disiplini elden bırakma!</p>
    </div>

    <div class="row g-4">
        @foreach (var gun in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 @(gun.Bolge == "Dinlenme" ? "bg-light opacity-75" : "")">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold text-primary mb-0">@gun.Gun</h5>
                            @if (gun.Bolge != "Dinlenme")
                            {
                                <span class="badge bg-primary rounded-pill">Aktif</span>
                            }
                        </div>
                    </div>
                    <div class="card-body px-4 pb-4">
                        <h4 class="fw-bold mb-3">@gun.Bolge</h4>

                        @if (gun.Bolge != "Dinlenme")
                        {
                            <div class="mb-2">
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Egzersizler</small>
                                <p class="mb-2 fw-semibold">@gun.HareketAdi</p>
                            </div>

                            <div class="d-flex gap-3">
                                <div class="bg-primary bg-opacity-10 p-2 rounded-3 flex-fill text-center">
                                    <span class="d-block small text-primary fw-bold">SET</span>
                                    <span class="h5 mb-0 fw-bold">@gun.Set</span>
                                </div>
                                <div class="bg-success bg-opacity-10 p-2 rounded-3 flex-fill text-center">
                                    <span class="d-block small text-success fw-bold">TEKRAR</span>
                                    <span class="h5 mb-0 fw-bold">@gun.Tekrar</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(gun.Aciklama))
                            {
                                <div class="mt-3 p-2 bg-warning bg-opacity-10 rounded-3 border-start border-warning border-3">
                                    <small class="d-block fw-bold text-warning" style="font-size: 0.7rem;">NOT / DİNLENME</small>
                                    <span class="small">@gun.Aciklama</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="fas fa-couch fa-3x text-muted mb-2"></i>
                                <p class="text-muted italic">Bugün kaslarını dinlendirme zamanı.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }
</style>