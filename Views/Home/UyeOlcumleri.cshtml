@model IEnumerable<SporSalonu.Models.Olcumler>

@{
    ViewData["Title"] = "Üye Ölçüm Detayları";
    var sonOlcum = Model.FirstOrDefault();
    var uyeAd = ViewBag.UyeAdSoyad;
    var uyeId = ViewBag.UyeId;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary">
                <i class="fas fa-weight me-2"></i> @uyeAd - Ölçüm Takibi
            </h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Uyeler" asp-action="Index" asp-route-mod="program">Üye Listesi</a></li>
                    <li class="breadcrumb-item active">Ölçümler</li>
                </ol>
            </nav>
        </div>
        <button class="btn btn-primary rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#yeniOlcumModal">
            <i class="fas fa-plus me-1"></i> Yeni Ölçüm Ekle
        </button>
    </div>

    <div class="row">
        <!-- İstatistik Özetleri -->
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <h6 class="text-uppercase opacity-75 small fw-bold">Son Ölçülen Kilo</h6>
                    <h1 class="display-4 fw-bold mb-0">@(sonOlcum?.Kilo ?? 0) <small class="fs-4">kg</small></h1>
                    <p class="mb-0 mt-2 opacity-75">Tarih: @(sonOlcum?.OlcumTarihi.ToString("dd.MM.yyyy") ?? "-")</p>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-transparent border-0 pt-3 ps-4">
                    <h5 class="fw-bold mb-0">Kilo Değişim Grafiği</h5>
                </div>
                <div class="card-body">
                    <canvas id="olcumGrafik" style="max-height: 250px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Ölçüm Geçmişi Tablosu -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 ps-4">
            <h5 class="fw-bold mb-0">Geçmiş Ölçümler</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Tarih</th>
                            <th>Kilo (kg)</th>
                            <th>Boy (cm)</th>
                            <th>Yağ Oranı (%)</th>
                            <th>Bel (cm)</th>
                            <th>Kol (cm)</th>
                            <th>Göğüs (cm)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">@item.OlcumTarihi.ToString("dd/MM/yyyy")</td>
                                    <td><span class="badge bg-primary-subtle text-primary fs-6">@item.Kilo</span></td>
                                    <td>@item.Boy</td>
                                    <td>%@item.YagOrani</td>
                                    <td>@item.BelCevresi</td>
                                    <td>@item.KolCevresi</td>
                                    <td>@item.GogusCevresi</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">Henüz ölçüm kaydı bulunmuyor.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Yeni Ölçüm Ekleme Modal -->
<div class="modal fade" id="yeniOlcumModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0">
                <h5 class="fw-bold">Yeni Ölçüm Verisi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Home" asp-action="OlcumEkle" method="post">
                <div class="modal-body">
                    <input type="hidden" name="UyeId" value="@uyeId" />

                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Kilo (kg)</label>
                            <input type="number" step="0.1" name="Kilo" class="form-control rounded-3" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Boy (cm)</label>
                            <input type="number" name="Boy" class="form-control rounded-3" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Yağ Oranı (%)</label>
                            <input type="number" step="0.1" name="YagOrani" class="form-control rounded-3" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Bel (cm)</label>
                            <input type="number" step="0.1" name="BelCevresi" class="form-control rounded-3" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Kol (cm)</label>
                            <input type="number" step="0.1" name="KolCevresi" class="form-control rounded-3" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Göğüs (cm)</label>
                            <input type="number" step="0.1" name="GogusCevresi" class="form-control rounded-3" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('olcumGrafik').getContext('2d');

        // C#'dan gelen verileri JS listesine çevirme (Tarihe göre sıralı olması için Reverse kullanıyoruz)
        const tarihler = [@Html.Raw(string.Join(",", Model.Reverse().Select(x => $"'{x.OlcumTarihi.ToString("dd/MM")}'")))];
        const kilolar = [@string.Join(",", Model.Reverse().Select(x => x.Kilo.ToString().Replace(",", ".")))];

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: tarihler,
                datasets: [{
                    label: 'Vücut Ağırlığı (kg)',
                    data: kilolar,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#0d6efd',
                    pointRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: false, grid: { display: false } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}