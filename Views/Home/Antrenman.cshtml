@model List<SporSalonu.Models.AntrenmanProgramlari>
@{
    ViewData["Title"] = "Antrenman Detayları";
    var gunler = new[] { "Pazartesi", "Salı", "Çarşamba", "Perşembe", "Cuma", "Cumartesi", "Pazar" };
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-clipboard-list text-primary me-2"></i>Haftalık Antrenman Planı</h2>
        <span class="badge bg-primary rounded-pill px-3 py-2">Nisan 2026</span>
    </div>

    <div class="row g-4">
        @foreach (var gun in gunler)
        {
            var program = Model.FirstOrDefault(x => x.Gun == gun);
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 @(DateTime.Now.ToString("dddd", new System.Globalization.CultureInfo("tr-TR")) == gun ? "border-start border-primary border-5" : "")">
                    <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between">
                        <h5 class="fw-bold mb-0">@gun</h5>
                        @if (DateTime.Now.ToString("dddd", new System.Globalization.CultureInfo("tr-TR")) == gun)
                        {
                            <span class="badge bg-success-soft text-success small">BUGÜN</span>
                        }
                    </div>
                    <div class="card-body px-4">
                        @if (program != null && program.Bolge != "Dinlenme")
                        {
                            <div class="mb-3">
                                <span class="text-muted small text-uppercase fw-bold">Odak Bölgesi</span>
                                <p class="h5 fw-bold text-dark">@program.Bolge</p>
                            </div>

                            <div class="p-3 bg-light rounded-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-dumbbell text-primary me-2"></i>
                                    <span class="fw-semibold">@program.HareketAdi</span>
                                </div>
                                <div class="d-flex gap-2">
                                    <span class="badge bg-white text-dark border shadow-sm">3 Set</span>
                                    <span class="badge bg-white text-dark border shadow-sm">12 Tekrar</span>
                                    <span class="badge bg-white text-dark border shadow-sm">60sn Dinlenme</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="fas fa-couch fa-2x text-muted mb-2 opacity-25"></i>
                                <p class="text-muted mb-0">Dinlenme Günü</p>
                                <small class="text-secondary">Kas gelişimi dinlenirken olur!</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .bg-success-soft {
        background-color: rgba(40, 167, 69, 0.1);
    }

    .card {
        transition: transform 0.2s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }
</style>