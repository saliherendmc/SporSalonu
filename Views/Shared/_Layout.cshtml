@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SporSalonu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .navbar-brand i {
            color: #0d6efd;
        }

        .nav-link:hover {
            color: #0d6efd !important;
            transition: 0.3s;
        }

        .user-badge {
            background: rgba(255,255,255,0.1);
            padding: 5px 15px;
            border-radius: 20px;
        }
    </style>
</head>
<body class="bg-light">
    <header>
        @{
            var userRole = HttpContextAccessor.HttpContext?.Session?.GetString("UserRole");
            var userEmail = HttpContextAccessor.HttpContext?.Session?.GetString("UserEmail");
        }

        @if (userEmail != null)
        {
            <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom shadow-sm mb-3 py-2">
                <div class="container">
                    <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="@(userRole == "Admin" ? "Index" : "Profilim")">
                        <i class="fas fa-dumbbell me-2"></i>SPOR SALONU
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            @if (userRole == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Yönetim Paneli</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Uyeler" asp-action="Index">Üye Listesi</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Home" asp-action="Profilim">Panelim</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Home" asp-action="OlcumEkle">Yeni Ölçüm</a>
                                </li>
                            }
                        </ul>

                        <div class="d-flex align-items-center gap-3">
                            <div class="user-badge text-light small d-none d-md-block">
                                <i class="fas fa-user-circle me-1"></i> @userEmail
                                <span class="badge bg-primary ms-1">@userRole</span>
                            </div>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                    <i class="fas fa-sign-out-alt me-1"></i> Çıkış
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </nav>
        }
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-auto shadow-sm">
        <div class="container py-3 text-center small">
            &copy; 2026 - <b>SporSalonu</b> Otomasyon Sistemi
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>